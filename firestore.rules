rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each class lives under classes/{classId}/...
    // Anyone can read. Only the class's own teacher (logged in) can write.
    match /classes/{classId}/{document=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.classId == classId;
    }

  }
}
